  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Delivery — SLO Burn Rates",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "title": "Delivery Latency Burn Rate (Fast: 5m / 1h)",
      "type": "timeseries",
      "targets": [
        {"expr": "slo:delivery_latency:burn_rate_5m{service=\"stream-analytics\"}", "legendFormat": "5m {{venue}}", "refId": "A"},
        {"expr": "slo:delivery_latency:burn_rate_1h{service=\"stream-analytics\"}", "legendFormat": "1h {{venue}}", "refId": "B"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 2,
      "title": "Delivery Latency Burn Rate (Slow: 30m / 6h)",
      "type": "timeseries",
      "targets": [
        {"expr": "slo:delivery_latency:burn_rate_30m{service=\"stream-analytics\"}", "legendFormat": "30m {{venue}}", "refId": "A"},
        {"expr": "slo:delivery_latency:burn_rate_6h{service=\"stream-analytics\"}", "legendFormat": "6h {{venue}}", "refId": "B"}
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 101,
      "title": "Delivery — WebSocket Latency",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 3,
      "title": "WS Send Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le, venue) (rate(ws_send_latency_ms_bucket[5m])))", "legendFormat": "p50 {{venue}}", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le, venue) (rate(ws_send_latency_ms_bucket[5m])))", "legendFormat": "p95 {{venue}}", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le, venue) (rate(ws_send_latency_ms_bucket[5m])))", "legendFormat": "p99 {{venue}}", "refId": "C"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 4,
      "title": "Delivery Latency Error Ratio (% > 250ms SLO)",
      "type": "timeseries",
      "targets": [
        {"expr": "slo:delivery_latency:error_ratio{service=\"stream-analytics\"}", "legendFormat": "{{venue}}", "refId": "A"}
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 102,
      "title": "Delivery — Throughput & Drops",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 19},
      "id": 5,
      "title": "WS Send Rate",
      "type": "timeseries",
      "targets": [
        {"expr": "sum by (venue) (rate(ws_send_latency_ms_count[5m]))", "legendFormat": "{{venue}}", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 19},
      "id": 6,
      "title": "WS Drops Rate",
      "type": "timeseries",
      "targets": [
        {"expr": "sum by (venue) (rate(ws_drops_total[5m]))", "legendFormat": "{{venue}}", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 19},
      "id": 7,
      "title": "Backpressure Drops Rate",
      "type": "timeseries",
      "targets": [
        {"expr": "sum by (venue) (rate(backpressure_drops_total[5m]))", "legendFormat": "{{venue}}", "refId": "A"}
      ]
    }
  ],
