# Copy to local.env and fill in real values.
# local.env is gitignored — never commit actual credentials.
#
# For local development you may use the defaults below.
# For production, use strong passwords and inject via vault/K8s secrets.

TIMESCALE_USER=raccoon
TIMESCALE_PASSWORD=raccoon
TIMESCALE_DB=raccoon

CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=password
CLICKHOUSE_DB=default

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
