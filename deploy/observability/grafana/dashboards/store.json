  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Store — Cold Path",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 1},
      "id": 1,
      "title": "Commit Rate by Status",
      "type": "timeseries",
      "targets": [
        {"expr": "sum by (status) (rate(store_commit_total[5m]))", "legendFormat": "{{status}}", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 1},
      "id": 2,
      "title": "Commit Latency (p50 / p95)",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(store_commit_latency_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(store_commit_latency_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B"}
      ]
    },
