{
  // Runtime config mounted in container at /etc/market-raccoon/consumer.jsonc
  "bus": {
    // "type": "inmemory"
    "type": "jetstream",
    // Wire format rollout knob: json (default) | proto (opt-in).
    "wire_format": "json"
  },
  "jetstream": {
    "url": "nats://nats:4222",
    "stream_name": "MARKETDATA",
    "consumer_durable": "consumer-v1",
    "ack_wait": "30s",
    "max_ack_pending": 1024,
    "max_deliver": 10,
    "deliver_policy": "all",
    "filter_subjects": ["marketdata.>"],
    "dedup_window": "5m",
    "max_age": "24h",
    "max_bytes": "10GB"
  },
  // Horizontal scaling: shard assignment for this instance.
  // Default: single-instance (index=0, count=1, sharding disabled).
  "shard": {
    "index": 0,
    "count": 1,
    // max_lag is the per-shard lag budget.  0 = no enforcement (default).
    "max_lag": 0
  },
  "log": {
    "level": "info",
    "format": "text"
  },
  "http": {
    "addr": ":8081",
    "shutdown_timeout": "10s"
  },
  "consumer": {
    "exchange": "binance",
    "tickers": ["BTC-USDT", "ETH-USDT"],
    "binance_ws_base_url": "wss://stream.binance.com:9443/stream",
    // Multi-exchange config (preferred over legacy single-exchange fields).
    "exchanges": [
      {
        "name": "binance-spot",
        "type": "binance",
        "tickers": ["BTCUSDT", "ETHUSDT"],
        "market_type": "SPOT"
      },
      {
        "name": "binance-futures",
        "type": "binance",
        "tickers": ["BTCUSDT", "ETHUSDT"],
        "market_type": "USD_M_FUTURES"
      },
      {
        "name": "bybit",
        "type": "bybit",
        "tickers": ["BTCUSDT", "ETHUSDT"],
        "market_type": "USD_M_FUTURES"
      },
      {
        "name": "coinbase",
        "type": "coinbase",
        "tickers": ["BTC-USD", "ETH-USD"],
        "market_type": "SPOT"
      },
      {
        "name": "hyperliquid",
        "type": "hyperliquid",
        "tickers": ["BTCUSDT", "ETHUSDT"],
        "market_type": "USD_M_FUTURES"
      }
    ],
    // Enables markprice/liquidation streams on supported exchanges.
    // When true for SPOT, streams_per_ticker must be 4.
    "enable_markprice_liquidation": false,
    "streams_per_ticker": 2,
    "max_streams_per_websocket": 200,
    "max_websockets": 5,
    "max_websocket_lifetime": "45m",
    "respawn_overlap": "5s"
  },
  "marketdata": {
    // "publish_content_type": "application/json"
    "publish_content_type": "application/json"
  }
}
